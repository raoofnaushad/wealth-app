# Platform API (auth, profile, company)
# Dev: /platform-api (proxied by Vite)
# Prod: full URL e.g. https://staging.asbitech.ai/asbi/api/v1
VITE_PLATFORM_API_URL=/platform-api

# Copilot API (chat trigger+poll, agents)
# Dev: /api (proxied by Vite to localhost:8000)
# Prod: full URL e.g. https://copilot.yourdomain.com
VITE_COPILOT_API_URL=/api

# General API (mock endpoints in dev, same as copilot in prod)
VITE_API_BASE_URL=/api
